# Build stage
FROM golang:1.25-alpine AS builder
RUN apk add --no-cache git ca-certificates
WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -ldflags="-w -s" -o /app/konductor-operator ./cmd/konductor-operator

# Final stage
FROM alpine:3.21
RUN apk add --no-cache ca-certificates tzdata
RUN adduser -D -u 65532 -g '' appuser
WORKDIR /app
COPY --from=builder /app/konductor-operator .
USER 65532
EXPOSE 8080 8081
ENTRYPOINT ["./konductor-operator"]
